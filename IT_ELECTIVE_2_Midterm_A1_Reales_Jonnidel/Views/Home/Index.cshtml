                    <img src="~/images/profile.jpg" alt="Jonnidel Reales - Professional Photo"
                         class="img-fluid rounded-circle hero-photo" />
                    <div class="hero-image-ring"></div>
                    <div class="hero-image-ring ring-2"></div>
                </div>
            </div>
        </div>
    </div>
</section>

