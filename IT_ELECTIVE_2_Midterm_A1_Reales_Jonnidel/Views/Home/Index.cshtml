<!-- SECTION: HOME / HERO                                         -->
<!-- ============================================================ -->
<section id="home" class="hero-section d-flex align-items-center min-vh-100">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-7 order-2 order-lg-1">
                <p class="hero-greeting mb-2 animate-fade-up">Hello, I'm</p>
                <h1 class="hero-name display-3 fw-800 mb-2 animate-fade-up delay-1">
                    Jonnidel <span class="text-gradient">Reales</span>
                </h1>
                <h2 class="hero-title h4 fw-400 text-secondary mb-4 animate-fade-up delay-2">
                    <i class="bi bi-code-slash me-2"></i>IT Student | Aspiring Game &amp; Web Developer
                </h2>
                <p class="hero-intro lead mb-4 animate-fade-up delay-3">
                    Hi, I'm Jonnidel Reales, a BSIT student with a passion for programming and technology.
                    I enjoy creating projects, exploring game development, and continuously improving my
                    skills in software development. I'm eager to learn new things and gain experience that
                    will help me grow as a future IT professional.
                </p>
                <div class="d-flex flex-wrap gap-3 animate-fade-up delay-4">
