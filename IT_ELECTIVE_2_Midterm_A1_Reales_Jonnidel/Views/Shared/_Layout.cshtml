<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Personal Portfolio - Aspiring Software Developer showcasing skills, projects, and experience." />
    <title>@ViewData["Title"] - Jonnidel Reales Portfolio</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/IT_ELECTIVE_2_Midterm_A1_Reales_Jonnidel.styles.css" asp-append-version="true" />
</head>
<body>

    <!-- Mobile Top Bar -->
    <nav class="navbar d-lg-none fixed-top mobile-topbar">
        <div class="container-fluid">
            <a class="navbar-brand text-white fw-bold" href="#">
                <i class="bi bi-code-slash me-2"></i>Portfolio
            </a>
            <button class="btn btn-outline-light" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas" aria-controls="sidebarOffcanvas">
                <i class="bi bi-list fs-4"></i>
            </button>
        </div>
    </nav>

    <!-- Offcanvas Sidebar for Mobile -->
    <div class="offcanvas offcanvas-start sidebar-offcanvas" tabindex="-1" id="sidebarOffcanvas" aria-labelledby="sidebarOffcanvasLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title text-white" id="sidebarOffcanvasLabel">
                <i class="bi bi-code-slash me-2"></i>Navigation
            </h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-0">
            <nav class="sidebar-nav-mobile">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link active" href="#home" data-bs-dismiss="offcanvas">
                            <i class="bi bi-house-door me-3"></i>Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#about" data-bs-dismiss="offcanvas">
                            <i class="bi bi-person me-3"></i>About Me
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#skills" data-bs-dismiss="offcanvas">
                            <i class="bi bi-gear me-3"></i>Skills
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#projects" data-bs-dismiss="offcanvas">
                            <i class="bi bi-folder me-3"></i>Projects
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#contact" data-bs-dismiss="offcanvas">
                            <i class="bi bi-envelope me-3"></i>Contact
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>

    <!-- Desktop Sidebar -->
    <aside class="sidebar d-none d-lg-flex flex-column" id="sidebar">
        <div class="sidebar-header text-center py-4">
            <div class="sidebar-avatar mx-auto mb-3">
                <img src="~/images/profile.jpg" alt="Profile Photo" class="rounded-circle img-fluid" />
            </div>
            <h5 class="sidebar-name mb-1">Jonnidel Reales</h5>
            <p class="sidebar-title mb-0">IT Student</p>
        </div>
        <hr class="sidebar-divider mx-3" />
        <nav class="sidebar-nav flex-grow-1">
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link active" href="#home" id="nav-home">
                        <i class="bi bi-house-door me-3"></i>Home
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#about" id="nav-about">
                        <i class="bi bi-person me-3"></i>About Me
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#skills" id="nav-skills">
                        <i class="bi bi-gear me-3"></i>Skills
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#projects" id="nav-projects">
                        <i class="bi bi-folder me-3"></i>Projects
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#contact" id="nav-contact">
                        <i class="bi bi-envelope me-3"></i>Contact
                    </a>
                </li>
            </ul>
        </nav>
        <div class="sidebar-footer text-center py-3">
            <div class="social-icons mb-2">
                <a href="https://github.com/WspJon" class="text-light me-3" target="_blank" title="GitHub"><i class="bi bi-github"></i></a>
                <a href="https://www.facebook.com/Realessst" class="text-light" target="_blank" title="Facebook"><i class="bi bi-facebook"></i></a>
            </div>
            <small class="text-secondary">&copy; 2026 Jonnidel Reales</small>
        </div>
    </aside>

    <!-- Main Content Area -->
    <div class="main-content" id="main-content">
        <main role="main">
            @RenderBody()
        </main>

        <footer class="site-footer text-center py-4 mt-5">
            <div class="container">
                <p class="mb-0 text-secondary">
                    &copy; 2026 Jonnidel Reales &mdash; Built with ASP.NET Core MVC &amp; Bootstrap
                </p>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
