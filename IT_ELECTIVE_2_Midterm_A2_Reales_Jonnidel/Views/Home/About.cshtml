@{
    ViewData["Title"] = "About Me";
}

<section id="about" class="section-padding">
    <div class="container">
        <div class="section-header text-center mb-5">
            <p class="section-subtitle text-gradient-sm text-uppercase fw-600 letter-spacing-2 mb-2">Get to Know Me</p>
            <h2 class="section-title display-5 fw-800">About Me</h2>
            <div class="section-divider mx-auto mt-3"></div>
        </div>
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="about-card glass-card p-4 h-100">
                    <div class="about-card-icon mb-3">
                        <i class="bi bi-person-lines-fill fs-2 text-gradient-icon"></i>
                    </div>
                    <h3 class="h5 fw-700 mb-3">@ViewData["BioTitle"]</h3>
                    <p>
                        @ViewData["BioParagraph1"]
                    </p>
                    <p>
                        @ViewData["BioParagraph2"]
                    </p>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="row g-4">
                    <div class="col-12">
                        <div class="about-card glass-card p-4">
                            <div class="about-card-icon mb-3">
                                <i class="bi bi-mortarboard-fill fs-2 text-gradient-icon"></i>
                            </div>
                            <h3 class="h5 fw-700 mb-3">Education</h3>
                            <div class="d-flex align-items-start mb-2">
                                <div class="edu-dot me-3 mt-2"></div>
                                <div>
                                    <p class="fw-600 mb-0">BS Information Technology (BSIT)</p>
                                    <p class="text-secondary mb-0">Lyceum of Alabang</p>
                                    <small class="text-muted">2023 &ndash; Present</small>
                                </div>
                            </div>
                            <div class="d-flex align-items-start">
                                <div class="edu-dot me-3 mt-2"></div>
                                <div>
                                    <p class="fw-600 mb-0">STEM Strand &ndash; Senior High School</p>
                                    <p class="text-secondary mb-0">Colegio De San Pedro</p>
                                    <small class="text-muted">2021 &ndash; 2023</small>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="about-card glass-card p-4">
                            <div class="about-card-icon mb-3">
                                <i class="bi bi-bullseye fs-2 text-gradient-icon"></i>
                            </div>
                            <h3 class="h5 fw-700 mb-3">Career Goals</h3>
                            <p class="mb-0">
                                @ViewData["CareerGoals"]
                            </p>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="about-card glass-card p-4">
                            <div class="about-card-icon mb-3">
                                <i class="bi bi-heart-fill fs-2 text-gradient-icon"></i>
                            </div>
                            <h3 class="h5 fw-700 mb-3">Personal Interests</h3>
                            <div class="d-flex flex-wrap gap-2">
                                <span class="interest-badge"><i class="bi bi-controller me-1"></i>Gaming</span>
                                <span class="interest-badge"><i class="bi bi-palette me-1"></i>Designing</span>
                                <span class="interest-badge"><i class="bi bi-code-slash me-1"></i>Programming</span>
                                <span class="interest-badge"><i class="bi bi-joystick me-1"></i>Game Dev</span>
                                <span class="interest-badge"><i class="bi bi-globe me-1"></i>Web Dev</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
