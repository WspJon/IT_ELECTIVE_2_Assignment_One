@{
    ViewData["Title"] = "Projects";
}

<section id="projects" class="section-padding">
    <div class="container">
        <div class="section-header text-center mb-5">
            <p class="section-subtitle text-gradient-sm text-uppercase fw-600 letter-spacing-2 mb-2">My Work</p>
            <h2 class="section-title display-5 fw-800">Projects</h2>
            <div class="section-divider mx-auto mt-3"></div>
        </div>
        <div class="row g-4">
            <!-- Project 1 -->
            <div class="col-md-6 col-lg-4">
                <div class="card project-card glass-card h-100 border-0 overflow-hidden">
                    <div class="card-body p-4">
                        <div class="project-icon-wrapper mb-3">
                            <i class="bi bi-book fs-1 text-gradient-icon"></i>
                        </div>
                        <span class="badge bg-gradient-subtle text-light mb-2">Console Application</span>
                        <h5 class="card-title fw-700 mb-2">@ViewData["Proj1Title"]</h5>
                        <p class="card-text text-secondary">
                            @ViewData["Proj1Desc"]
                        </p>
                        <div class="tech-stack mb-3">
                            <span class="tech-badge">C#</span>
                            <span class="tech-badge">.NET Console</span>
                            <span class="tech-badge">OOP</span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 p-4 pt-0">
                        <a href="#" class="btn btn-gradient btn-sm w-100 py-2">
                            <i class="bi bi-arrow-right-circle me-2"></i>View Details
                        </a>
                    </div>
                </div>
            </div>
            <!-- Project 2 -->
            <div class="col-md-6 col-lg-4">
                <div class="card project-card glass-card h-100 border-0 overflow-hidden">
                    <div class="card-body p-4">
                        <div class="project-icon-wrapper mb-3">
                            <i class="bi bi-car-front fs-1 text-gradient-icon"></i>
                        </div>
                        <span class="badge bg-gradient-subtle text-light mb-2">Console Application</span>
                        <h5 class="card-title fw-700 mb-2">@ViewData["Proj2Title"]</h5>
                        <p class="card-text text-secondary">
                            @ViewData["Proj2Desc"]
                        </p>
                        <div class="tech-stack mb-3">
                            <span class="tech-badge">C#</span>
                            <span class="tech-badge">.NET Console</span>
                            <span class="tech-badge">Data Structures</span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 p-4 pt-0">
                        <a href="#" class="btn btn-gradient btn-sm w-100 py-2">
                            <i class="bi bi-arrow-right-circle me-2"></i>View Details
                        </a>
                    </div>
                </div>
            </div>
            <!-- Project 3 -->
            <div class="col-md-6 col-lg-4">
                <div class="card project-card glass-card h-100 border-0 overflow-hidden">
                    <div class="card-body p-4">
                        <div class="project-icon-wrapper mb-3">
                            <i class="bi bi-search fs-1 text-gradient-icon"></i>
                        </div>
                        <span class="badge bg-gradient-subtle text-light mb-2">Console Application</span>
                        <h5 class="card-title fw-700 mb-2">@ViewData["Proj3Title"]</h5>
                        <p class="card-text text-secondary">
                            @ViewData["Proj3Desc"]
                        </p>
                        <div class="tech-stack mb-3">
                            <span class="tech-badge">Python</span>
                            <span class="tech-badge">Console App</span>
                            <span class="tech-badge">Dictionary</span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 p-4 pt-0">
                        <a href="#" class="btn btn-gradient btn-sm w-100 py-2">
                            <i class="bi bi-arrow-right-circle me-2"></i>View Details
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
