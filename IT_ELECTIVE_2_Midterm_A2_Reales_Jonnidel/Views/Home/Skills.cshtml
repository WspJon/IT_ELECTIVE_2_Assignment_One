@{
    ViewData["Title"] = "Skills";
}

<section id="skills" class="section-padding">
    <div class="container">
        <div class="section-header text-center mb-5">
            <p class="section-subtitle text-gradient-sm text-uppercase fw-600 letter-spacing-2 mb-2">What I Know</p>
            <h2 class="section-title display-5 fw-800">@ViewData["SectionTitle"]</h2>
            <div class="section-divider mx-auto mt-3"></div>
        </div>
        <div class="row g-4">
            <!-- Programming Languages -->
            <div class="col-md-6 col-lg-3">
                <div class="card skill-card glass-card h-100 border-0 text-center p-4">
                    <div class="skill-icon-wrapper mx-auto mb-4">
                        <i class="bi bi-braces fs-1"></i>
                    </div>
                    <div class="card-body p-0">
                        <h5 class="card-title fw-700 mb-3">Programming Languages</h5>
                        <div class="skill-tags">
                            <span class="skill-tag">Python</span>
                            <span class="skill-tag">C#</span>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Web Technologies -->
            <div class="col-md-6 col-lg-3">
                <div class="card skill-card glass-card h-100 border-0 text-center p-4">
                    <div class="skill-icon-wrapper mx-auto mb-4">
                        <i class="bi bi-globe fs-1"></i>
                    </div>
                    <div class="card-body p-0">
                        <h5 class="card-title fw-700 mb-3">Web Technologies</h5>
                        <div class="skill-tags">
                            <span class="skill-tag">HTML5</span>
                            <span class="skill-tag">CSS3</span>
                            <span class="skill-tag">Bootstrap</span>
                            <span class="skill-tag">ASP.NET Core</span>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Databases -->
            <div class="col-md-6 col-lg-3">
                <div class="card skill-card glass-card h-100 border-0 text-center p-4">
                    <div class="skill-icon-wrapper mx-auto mb-4">
                        <i class="bi bi-database fs-1"></i>
                    </div>
                    <div class="card-body p-0">
                        <h5 class="card-title fw-700 mb-3">Databases</h5>
                        <div class="skill-tags">
                            <span class="skill-tag">MySQL</span>
                            <span class="skill-tag">SQL Server</span>
                            <span class="skill-tag">SQLite</span>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Development Tools -->
            <div class="col-md-6 col-lg-3">
                <div class="card skill-card glass-card h-100 border-0 text-center p-4">
                    <div class="skill-icon-wrapper mx-auto mb-4">
                        <i class="bi bi-tools fs-1"></i>
                    </div>
                    <div class="card-body p-0">
                        <h5 class="card-title fw-700 mb-3">Development Tools</h5>
                        <div class="skill-tags">
                            <span class="skill-tag">Visual Studio</span>
                            <span class="skill-tag">VS Code</span>
                            <span class="skill-tag">Git</span>
                            <span class="skill-tag">GitHub</span>
                            <span class="skill-tag">Unity</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
